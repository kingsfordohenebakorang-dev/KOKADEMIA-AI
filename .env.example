# API Configuration
API_PORT=3000
NODE_ENV=development

# Authentication (REQUIRED - minimum 32 characters each)
JWT_SECRET=your-secret-key-here-must-be-at-least-32-chars
JWT_EXPIRATION=24h
NEXTAUTH_SECRET=your-nextauth-secret-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000
SESSION_SECRET=your-session-secret-here

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kokademia
DB_USER=db_user
DB_PASSWORD=change-me

# External Services
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_...

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# TestSprite (optional)
TESTSPRITE_API_KEY=sk-user-...
